# VivahGo environment variables
# Copy this file to vivahgo/.env for local development.
# For Vercel, add the same server/client variables in the project settings.

# ---------------------------------------------------------------------------
# Frontend (Vite)
# These are exposed to the browser, so only use VITE_ for safe public values.
# ---------------------------------------------------------------------------

# Google OAuth Web Client ID used by the frontend Google sign-in button.
# Use the same value for GOOGLE_CLIENT_ID below.
VITE_GOOGLE_CLIENT_ID=your-google-web-client-id

# Clerk Publishable Key for React (Vite)
VITE_CLERK_PUBLISHABLE_KEY=your-clerk-publishable-key

# API base URL for the frontend.
# Local default: http://localhost:4000/api
# Production on Vercel can usually omit this and use /api automatically.
VITE_API_BASE_URL=http://localhost:4000/api

# Set to true only if you want localhost frontend to call a remote API.
VITE_USE_REMOTE_API=false

# Optional site URL override used by frontend SEO metadata.
# If omitted, the app falls back to the current deployed origin, or
# https://vivahgo.com when running locally.
VITE_SITE_URL=https://vivahgo.com

# Optional Chatbase chatbot ID for the home/pricing support widget.
# Preferred key for this Vite app:
VITE_CHATBASE_CHATBOT_ID=
# Optional custom host. Defaults to https://www.chatbase.co/
VITE_CHATBASE_HOST=https://www.chatbase.co/

# Compatibility: if your Vercel/root env already uses Next-style names,
# the app also accepts these.
NEXT_PUBLIC_CHATBASE_CHATBOT_CHATBOT_ID=
NEXT_PUBLIC_CHATBASE_CHATBOT_CHATBASE_HOST=https://www.chatbase.co/

# ---------------------------------------------------------------------------
# Core backend / API
# Required in production unless explicitly marked optional.
# ---------------------------------------------------------------------------

# Local Express port. Not usually needed for Vercel serverless functions.
PORT=4000

# MongoDB connection string. Required for auth, planner, vendors, careers,
# subscriptions, and admin data.
MONGODB_URI=mongodb://127.0.0.1:27017/vivahgo

# Google OAuth Web Client ID used by the backend to verify Google ID tokens.
# Keep this equal to VITE_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=your-google-web-client-id

# Required in production. Used to sign auth/session JWTs.
# Never leave this as a placeholder in deployed environments.
JWT_SECRET=replace-with-a-long-random-secret

# Optional. If omitted, RSVP tokens fall back to JWT_SECRET.
RSVP_TOKEN_SECRET=

# Comma-separated list of allowed frontend origins for API CORS.
# Add your deployed frontend domain in production.
CLIENT_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,https://your-production-domain.com

# Optional canonical site URL overrides used by the server-rendered page handler.
# Usually one of these is enough if you need to override the default
# https://vivahgo.com metadata origin.
SITE_URL=https://vivahgo.com
PUBLIC_SITE_URL=https://vivahgo.com

# Feedback form webhook target and shared secret.
FEEDBACK_WEBHOOK_URL=https://script.google.com/macros/s/your-script-id/exec
FEEDBACK_SECRET_KEY=replace-with-feedback-secret

# JSON array of subscription coupons.
# Example format:
# [{"code":"WELCOME10","expiresAt":"2099-12-31T23:59:59.000Z","discountPercent":10,"applicablePlans":["premium","studio"]}]
SUBSCRIPTION_COUPONS_JSON=[{"code":"WELCOME10","expiresAt":"2099-12-31T23:59:59.000Z","discountPercent":10}]

# ---------------------------------------------------------------------------
# Razorpay subscriptions
# Required if paid subscriptions are enabled.
# Amounts are in paise.
# ---------------------------------------------------------------------------

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PREMIUM_MONTHLY_AMOUNT=200000
RAZORPAY_PREMIUM_YEARLY_AMOUNT=1920000
RAZORPAY_STUDIO_MONTHLY_AMOUNT=500000
RAZORPAY_STUDIO_YEARLY_AMOUNT=4800000

# ---------------------------------------------------------------------------
# Billing emails
# Optional. If unset, billing receipts are created but email delivery is skipped.
# ---------------------------------------------------------------------------

RESEND_API_KEY=
BILLING_FROM_EMAIL=billing@your-domain.com

# Careers rejection emails sent from the admin console.
# Optional unless you want one-click rejection emails from Careers admin.
CAREERS_SMTP_HOST=smtp-relay.brevo.com
CAREERS_SMTP_PORT=587
CAREERS_SMTP_LOGIN=
CAREERS_SMTP_PASSWORD=
CAREERS_SMTP_FROM_EMAIL=careers@your-domain.com

# ---------------------------------------------------------------------------
# Cloudflare R2 media storage
# Required for vendor/media upload flows.
# ---------------------------------------------------------------------------

R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET_NAME=vivahgo-media

# Public base URL used to generate asset URLs.
# Example:
# https://media.vivahgo.com/portfolio
R2_PUBLIC_URL=https://media.vivahgo.com/portfolio

# ---------------------------------------------------------------------------
# Admin / staff
# Optional. If unset, the code falls back to the bootstrap owner email baked in
# to the server, but setting this explicitly is safer for production.
# ---------------------------------------------------------------------------

ADMIN_OWNER_EMAIL=owner@your-domain.com

# ---------------------------------------------------------------------------
# Firebase web messaging / Premium reminders
# Required for browser push + scheduled reminder delivery.
# ---------------------------------------------------------------------------

# Public web app config from Firebase Project Settings -> Your apps -> Web app.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Web Push certificate key from Firebase Cloud Messaging -> Web configuration.
VITE_FIREBASE_VAPID_KEY=

# Backend FCM sender config.
# Option A: provide the individual service account values below.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Option B: provide the entire Firebase service account JSON as one env var.
# If this is set, the backend can read project_id / client_email / private_key
# directly from it.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Shared secret used by Cloudflare cron to call the internal dispatch endpoint.
REMINDER_DISPATCH_SECRET=replace-with-a-long-random-secret

# ---------------------------------------------------------------------------
# Careers / resume upload to Backblaze B2
# Required for the careers form resume upload feature.
# Sign up free at https://www.backblaze.com/cloud-storage (10GB free)
# ---------------------------------------------------------------------------

B2_ACCESS_KEY_ID=
B2_SECRET_ACCESS_KEY=
B2_ENDPOINT=
B2_BUCKET_NAME=
