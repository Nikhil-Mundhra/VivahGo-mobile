# VivahGo environment variables
# Copy this file to vivahgo/.env for local development.
# For Vercel, add the same server/client variables in the project settings.

# ---------------------------------------------------------------------------
# Frontend (Vite)
# These are exposed to the browser, so only use VITE_ for safe public values.
# ---------------------------------------------------------------------------

# Google OAuth Web Client ID used by the frontend Google sign-in button.
# Use the same value for GOOGLE_CLIENT_ID below.
VITE_GOOGLE_CLIENT_ID=your-google-web-client-id

# API base URL for the frontend.
# Local default: http://localhost:4000/api
# Production on Vercel can usually omit this and use /api automatically.
VITE_API_BASE_URL=http://localhost:4000/api

# Set to true only if you want localhost frontend to call a remote API.
VITE_USE_REMOTE_API=false

# ---------------------------------------------------------------------------
# Core backend / API
# Required in production unless explicitly marked optional.
# ---------------------------------------------------------------------------

# Local Express port. Not usually needed for Vercel serverless functions.
PORT=4000

# MongoDB connection string. Required for auth, planner, vendors, careers,
# subscriptions, and admin data.
MONGODB_URI=mongodb://127.0.0.1:27017/vivahgo

# Google OAuth Web Client ID used by the backend to verify Google ID tokens.
# Keep this equal to VITE_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=your-google-web-client-id

# Required in production. Used to sign auth/session JWTs.
# Never leave this as a placeholder in deployed environments.
JWT_SECRET=replace-with-a-long-random-secret

# Optional. If omitted, RSVP tokens fall back to JWT_SECRET.
RSVP_TOKEN_SECRET=

# Comma-separated list of allowed frontend origins for API CORS.
# Add your deployed frontend domain in production.
CLIENT_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,https://your-production-domain.com

# Feedback form webhook target and shared secret.
FEEDBACK_WEBHOOK_URL=https://script.google.com/macros/s/your-script-id/exec
FEEDBACK_SECRET_KEY=replace-with-feedback-secret

# JSON array of subscription coupons.
# Example format:
# [{"code":"WELCOME10","expiresAt":"2099-12-31T23:59:59.000Z","discountPercent":10,"applicablePlans":["premium","studio"]}]
SUBSCRIPTION_COUPONS_JSON=[{"code":"WELCOME10","expiresAt":"2099-12-31T23:59:59.000Z","discountPercent":10}]

# ---------------------------------------------------------------------------
# Razorpay subscriptions
# Required if paid subscriptions are enabled.
# Amounts are in paise.
# ---------------------------------------------------------------------------

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PREMIUM_MONTHLY_AMOUNT=200000
RAZORPAY_PREMIUM_YEARLY_AMOUNT=1920000
RAZORPAY_STUDIO_MONTHLY_AMOUNT=500000
RAZORPAY_STUDIO_YEARLY_AMOUNT=4800000

# ---------------------------------------------------------------------------
# Billing emails
# Optional. If unset, billing receipts are created but email delivery is skipped.
# ---------------------------------------------------------------------------

RESEND_API_KEY=
BILLING_FROM_EMAIL=billing@your-domain.com

# ---------------------------------------------------------------------------
# Cloudflare R2 media storage
# Required for vendor/media upload flows.
# ---------------------------------------------------------------------------

R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET_NAME=vivahgo-media

# Public base URL used to generate asset URLs.
# Example:
# https://media.vivahgo.com/portfolio
R2_PUBLIC_URL=https://media.vivahgo.com/portfolio

# ---------------------------------------------------------------------------
# Admin / staff
# Optional. If unset, the code falls back to the bootstrap owner email baked in
# to the server, but setting this explicitly is safer for production.
# ---------------------------------------------------------------------------

ADMIN_OWNER_EMAIL=owner@your-domain.com

# ---------------------------------------------------------------------------
# Careers / resume upload to Google Drive
# Required only if the careers form and resume upload are enabled.
# GOOGLE_DRIVE_PRIVATE_KEY should preserve line breaks. In platforms like Vercel,
# paste the full key and let the app convert escaped \\n sequences automatically.
# ---------------------------------------------------------------------------

GOOGLE_DRIVE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_DRIVE_PRIVATE_KEY=
GOOGLE_DRIVE_CAREERS_FOLDER_ID=
