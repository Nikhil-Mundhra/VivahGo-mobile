{
  "name": "vivah-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite",
    "dev:server": "node --watch server/index.js",
    "generate:public-asset-map": "node ../scripts/generate-public-asset-map.cjs",
    "generate:guides-feed": "node ../scripts/generate-guides-feed.cjs",
    "prebuild": "npm run generate:public-asset-map && npm run generate:guides-feed",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start:server": "node server/index.js"
  },
  "dependencies": {
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@clerk/react": "^6.1.4",
    "@react-oauth/google": "^0.13.4",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "firebase": "^12.11.0",
    "framer-motion": "^12.38.0",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.2",
    "jwt-decode": "^4.0.0",
    "mongodb": "^7.1.1",
    "mongoose": "^9.4.1",
    "razorpay": "^2.9.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.6.1",
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.3"
  }
}
