{
  "scripts": {
    "build": "cd vivahgo && npm run build",
    "dev": "cd vivahgo && npm run dev",
    "generate:seo-keywords": "node scripts/generate-seo-keywords.cjs",
    "lint": "cd vivahgo && npm run lint",
    "test": "mocha \"test/**/*.test.cjs\"",
    "verify:seo": "node scripts/verify-seo.cjs",
    "test:coverage": "c8 --reporter=text-summary --reporter=lcov --reporter=html --include=api/**/*.js --include=vivahgo/server/**/*.js --include=vivahgo/src/**/*.js mocha \"test/**/*.test.cjs\"",
    "coverage:check": "c8 --check-coverage --statements 90 --branches 0 --functions 0 --lines 0 --include=api/**/*.js --include=vivahgo/server/**/*.js --include=vivahgo/src/**/*.js mocha \"test/**/*.test.cjs\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1016.0",
    "@aws-sdk/s3-request-presigner": "3.1016.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/ios": "^8.2.0",
    "@clerk/nextjs": "^7.0.8",
    "@vercel/blob": "^2.3.3",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.19.3",
    "nodemailer": "^8.0.4",
    "razorpay": "^2.9.6"
  },
  "devDependencies": {
    "c8": "^10.1.3",
    "jsdom": "^29.0.1",
    "mocha": "^11.7.4",
    "nyc": "^18.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "supertest": "^7.1.4"
  },
  "nyc": {
    "all": true,
    "extension": [
      ".js",
      ".cjs"
    ],
    "include": [
      "api/**/*.js",
      "vivahgo/server/**/*.js",
      "vivahgo/src/**/*.js"
    ],
    "exclude": [
      "test/**",
      "**/*.test.cjs",
      "**/node_modules/**"
    ],
    "report-dir": "coverage",
    "temp-dir": ".nyc_output",
    "cache": true,
    "sourceMap": true,
    "instrument": true
  }
}
