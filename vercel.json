{
  "installCommand": "npm install && npm install --prefix vivahgo",
  "buildCommand": "npm --prefix vivahgo run build",
  "outputDirectory": "vivahgo/dist",
  "functions": {
    "api/page.js": {
      "includeFiles": "vivahgo/dist/index.html"
    }
  },
  "rewrites": [
    { "source": "/api/auth/google", "destination": "/api/auth?route=google" },
    { "source": "/api/auth/csrf", "destination": "/api/auth?route=csrf" },
    { "source": "/api/auth/me", "destination": "/api/auth?route=me" },
    { "source": "/api/auth/logout", "destination": "/api/auth?route=logout" },
    { "source": "/api/admin/me", "destination": "/api/admin?route=me" },
    { "source": "/api/admin/vendors", "destination": "/api/admin?route=vendors" },
    { "source": "/api/admin/choice", "destination": "/api/admin?route=choice" },
    { "source": "/api/admin/choice-media-upload", "destination": "/api/admin?route=choice-media-upload" },
    { "source": "/api/admin/staff", "destination": "/api/admin?route=staff" },
    { "source": "/api/admin/applications", "destination": "/api/admin?route=applications" },
    { "source": "/api/admin/resume-download", "destination": "/api/admin?route=resume-download" },
    { "source": "/api/admin/subscribers", "destination": "/api/admin?route=subscribers" },
    { "source": "/api/careers", "destination": "/api/careers" },
    { "source": "/api/feedback", "destination": "/api/system?route=feedback" },
    { "source": "/api/health", "destination": "/api/system?route=health" },
    { "source": "/api/media/app-upload", "destination": "/api/media?route=app-upload" },
    { "source": "/api/media/presigned-url", "destination": "/api/media?route=presigned-url" },
    { "source": "/api/media/verification-presigned-url", "destination": "/api/media?route=verification-presigned-url" },
    { "source": "/api/vendors", "destination": "/api/vendors" },
    { "source": "/api/vendor/me", "destination": "/api/vendor?route=me" },
    { "source": "/api/vendor/media", "destination": "/api/vendor?route=media" },
    { "source": "/api/vendor/verification", "destination": "/api/vendor?route=verification" },
    { "source": "/api/planner/access", "destination": "/api/planner?route=access" },
    { "source": "/api/planner/public", "destination": "/api/planner-public" },
    { "source": "/api/planner/rsvp", "destination": "/api/planner?route=rsvp" },
    { "source": "/api/planner/me/rsvp-link", "destination": "/api/planner?route=rsvp-link" },
    { "source": "/api/planner/me/collaborators", "destination": "/api/planner?route=collaborators" },
    { "source": "/api/planner/me/notifications", "destination": "/api/planner?route=notifications" },
    { "source": "/api/planner/internal/reminder-dispatch", "destination": "/api/planner?route=reminder-dispatch" },
    { "source": "/api/planner/me", "destination": "/api/planner?route=me" },
    { "source": "/api/subscription/status", "destination": "/api/subscription?op=status" },
    { "source": "/api/subscription/quote", "destination": "/api/subscription?op=quote" },
    { "source": "/api/subscription/checkout", "destination": "/api/subscription?op=checkout" },
    { "source": "/api/subscription/confirm", "destination": "/api/subscription?op=confirm" },
    { "source": "/api/subscription/portal", "destination": "/api/subscription?op=portal" },
    { "source": "/api/subscription/webhook", "destination": "/api/subscription?op=webhook" },
    {
      "source": "/",
      "has": [
        { "type": "host", "value": "planner.vivahgo.com" }
      ],
      "destination": "/index.html"
    },
    { "source": "/", "destination": "/api/page?route=home" },
    { "source": "/home", "destination": "/api/page?route=home" },
    { "source": "/pricing", "destination": "/api/page?route=pricing" },
    { "source": "/guides", "destination": "/api/page?route=guides" },
    { "source": "/guides/:slug", "destination": "/api/page?route=guide&slug=:slug" },
    { "source": "/wedding-planner-app", "destination": "/api/page?route=query&slug=wedding-planner-app" },
    { "source": "/wedding-checklist-app", "destination": "/api/page?route=query&slug=wedding-checklist-app" },
    { "source": "/wedding-budget-planner-app", "destination": "/api/page?route=query&slug=wedding-budget-planner-app" },
    { "source": "/guest-list-rsvp-app", "destination": "/api/page?route=query&slug=guest-list-rsvp-app" },
    { "source": "/wedding-vendor-manager-app", "destination": "/api/page?route=query&slug=wedding-vendor-manager-app" },
    { "source": "/indian-wedding-budget-template", "destination": "/api/page?route=query&slug=indian-wedding-budget-template" },
    { "source": "/free-wedding-budget-template", "destination": "/api/page?route=query&slug=free-wedding-budget-template" },
    { "source": "/wedding-guest-list-template", "destination": "/api/page?route=query&slug=wedding-guest-list-template" },
    { "source": "/for-wedding-planners", "destination": "/api/page?route=query&slug=for-wedding-planners" },
    { "source": "/careers", "destination": "/api/page?route=careers" },
    { "source": "/wedding", "destination": "/api/page?route=wedding" },
    { "source": "/rsvp/:token", "destination": "/api/page?route=rsvp&token=:token" },
    { "source": "/:slug((?!api|home|pricing|guides|wedding|vendor|admin|careers|rsvp|robots\\.txt|sitemap\\.xml|logo\\.svg|icons\\.svg|Thumbnail\\.png).+)", "destination": "/api/page?route=website&slug=:slug" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
